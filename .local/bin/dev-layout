#!/bin/bash
SESSION="dev"

# 既存セッションがあればアタッチ
tmux has-session -t $SESSION 2>/dev/null
if [ $? -eq 0 ]; then
  tmux attach -t $SESSION
  exit 0
fi

# 新規セッション作成
tmux new-session -d -s $SESSION -c "$HOME"

# 右側にClaude用ペイン（右50%）
tmux split-window -h -l 50% -t $SESSION
tmux send-keys -t $SESSION 'claude' C-m

# 最初のフォーカスを左shellに
tmux select-pane -t $SESSION:0.0

# アタッチ
tmux attach -t $SESSION
