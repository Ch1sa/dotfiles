# === フォント ===
# フォントファミリー
font-family = JetBrainsMono Nerd Font Mono
# フォントサイズ
font-size = 14
# 行間を少し広げて見やすくする
adjust-cell-height = 10%

# === テーマ・背景 ===
# カラーテーマ
theme = Ollie
# 背景の透過度
background-opacity = 0.90
# すりガラス風のぼかし効果
background-blur-radius = 20

# === ウィンドウ ===
# 左右の余白
window-padding-x = 10
# 上下の余白
window-padding-y = 10
# 余白を均等に配分する
window-padding-balance = true

# === 操作 ===
# 入力中はマウスカーソルを隠す
mouse-hide-while-typing = true
# 選択するだけでコピー
copy-on-select = true
# クリップボードの読み書きを許可
clipboard-read = allow
clipboard-write = allow

# === キーバインド：画面分割 ===
# tmuxの分割に統一するため、Ghosttyのネイティブ分割は無効化
keybind = ctrl+enter=unbind
keybind = ctrl+shift+enter=unbind

# === キーバインド：分割画面の移動 ===
keybind = ctrl+alt+left=unbind
keybind = ctrl+alt+right=unbind
keybind = ctrl+alt+up=unbind
keybind = ctrl+alt+down=unbind

# === キーバインド：分割サイズの調整 ===
keybind = ctrl+shift+left=unbind
keybind = ctrl+shift+right=unbind
keybind = ctrl+shift+up=unbind
keybind = ctrl+shift+down=unbind

# === キーバインド：その他 ===
# 現在のペインを閉じる
keybind = ctrl+w=close_surface

