# === フォント ===
# フォントファミリー
font-family = JetBrainsMono Nerd Font Mono
# フォントサイズ
font-size = 14
# 行間を少し広げて見やすくする
adjust-cell-height = 10%

# === テーマ・背景 ===
# カラーテーマ
theme = Ollie
# 背景の透過度
background-opacity = 0.90
# すりガラス風のぼかし効果
background-blur-radius = 20

# === ウィンドウ ===
# 左右の余白
window-padding-x = 10
# 上下の余白
window-padding-y = 10
# 余白を均等に配分する
window-padding-balance = true

# === 操作 ===
# 入力中はマウスカーソルを隠す
mouse-hide-while-typing = true
# 選択するだけでコピー
copy-on-select = true
# クリップボードの読み書きを許可
clipboard-read = allow
clipboard-write = allow

# === キーバインド：画面分割 ===
# 下に分割
keybind = ctrl+enter=new_split:down
# 右に分割
keybind = ctrl+shift+enter=new_split:right

# === キーバインド：分割画面の移動 ===
# 左のペインへ移動
keybind = ctrl+alt+left=goto_split:left
# 右のペインへ移動
keybind = ctrl+alt+right=goto_split:right
# 上のペインへ移動
keybind = ctrl+alt+up=goto_split:top
# 下のペインへ移動
keybind = ctrl+alt+down=goto_split:bottom

# === キーバインド：分割サイズの調整 ===
# 左に広げる
keybind = ctrl+shift+left=resize_split:left,20
# 右に広げる
keybind = ctrl+shift+right=resize_split:right,20
# 上に広げる
keybind = ctrl+shift+up=resize_split:up,20
# 下に広げる
keybind = ctrl+shift+down=resize_split:down,20

# === キーバインド：その他 ===
# 現在のペインを閉じる
keybind = ctrl+w=close_surface

